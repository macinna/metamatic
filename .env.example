# Development environment variables for Metamatic backend
# Copy this to .env.local and customize for your local setup

# General settings
STAGE=dev
LOG_LEVEL=DEBUG
AWS_REGION=us-east-1

# Agent service settings
AGENT_MODEL_ID=us.amazon.nova-lite-v1:0

# API service settings
JWT_SECRET=your-dev-jwt-secret-here
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database settings (when needed)
# DATABASE_URL=postgresql://localhost:5432/metamatic_dev

# AWS settings for local development
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_DEFAULT_REGION=us-east-1
